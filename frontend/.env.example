# Run "terraform output" after deploying infrastructure to get these values

# API Gateway invoke URL (from terraform output api_gateway_url)
REACT_APP_API_URL=https://xxxxxxxxxx.execute-api.us-east-2.amazonaws.com/prod

# Cognito User Pool ID (from terraform output cognito_user_pool_id)
REACT_APP_COGNITO_USER_POOL=us-east-2_xxxxxxxxx

# Cognito App Client ID (from terraform output cognito_client_id)
REACT_APP_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS region
REACT_APP_COGNITO_REGION=us-east-2

# Base URL for short links shown in the UI
# If using CloudFront: https://xxxxxxxxxxxx.cloudfront.net
# Same as your CloudFront URL (from terraform output cloudfront_url)
REACT_APP_SHORT_BASE=https://xxxxxxxxxxxx.cloudfront.net
